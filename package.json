{
  "name": "cdk-express-mode",
  "version": "0.1.0",
  "description": "AWS CloudFormation and CDK Express Mode の効果を実測検証するプロジェクト",
  "bin": {
    "cdk-express-mode": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "synth": "cdk synth",
    "deploy:normal": "cdk deploy --all -c prefix=normal",
    "deploy:express": "cdk deploy --all -c prefix=express --express",
    "destroy:normal": "cdk destroy --all -c prefix=normal",
    "destroy:express": "cdk destroy --all -c prefix=express"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "aws-cdk": "^2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5"
  },
  "dependencies": {
    "aws-cdk-lib": "^2",
    "cdk-nag": "^2",
    "constructs": "^10.3.0"
  }
}
